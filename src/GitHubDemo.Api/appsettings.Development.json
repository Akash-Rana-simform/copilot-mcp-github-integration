{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "GitHubDemo.Api.Services.WebhookService": "Information"
    }
  },
  "AllowedHosts": "*",
  "WebhookSecret": "your-webhook-secret-from-github",
  "WebhookSettings": {
    "MaxPayloadSize": 1048576,
    "EnableLogging": true,
    "RetentionDays": 30
  }
}
